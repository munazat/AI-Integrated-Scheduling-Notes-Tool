# ============================================
# Frontend (.env.local in apps/web)
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# ============================================
# Backend (.env in apps/api)
# ============================================
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/ai-scheduler?retryWrites=true&w=majority
# Use MongoDB Atlas for the easiest setup.
# If you want local MongoDB, replace this with a local connection string.

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Session/Auth
SESSION_SECRET=your_random_secret_key_min_32_chars_long

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://:password@redis-host:6379 (for production)

# Logging
LOG_LEVEL=debug
